# Copy this file to .env and paste your key.
# Create a key at: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_your_key_here

# Career Copilot retail license (from purchase or CCOP-TRIAL for 14-day trial)
# CAREER_COPILOT_LICENSE=CCOP-XXXX-XXXX-XXXX

# Optional: override the model the lab uses (default: composer-2.5).
# Use "auto" to let the server pick.
# CURSOR_LAB_MODEL=composer-2.5
